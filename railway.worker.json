{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "startCommand": "sh -c \"sh /var/www/docker/wait-for-db.sh && php artisan queue:work --tries=3 --max-time=3600 --sleep=3 --backoff=60,300,600\"",
    "sleepApplication": false
  }
}
