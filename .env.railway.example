# ─────────────────────────────────────────────────────────────────────────────
# TheraConnect — Railway environment variables (pilot/demo deployment)
#
# These are DOCUMENTATION. Do NOT commit real secrets. Set these in the Railway
# service's "Variables" tab. The ${{MySQL.*}} values are Railway references that
# auto-fill once you add the MySQL plugin to the project.
#
# Steps:
#   1. Generate APP_KEY locally:  php artisan key:generate --show
#   2. Add the MySQL database plugin in the Railway project.
#   3. Paste these variables; fill APP_URL + SANCTUM_STATEFUL_DOMAINS + CORS_AFTER you
#      generate a public domain (Settings → Networking → Generate Domain), then redeploy.
#   4. (Recommended) Create two additional Railway services:
#        - Queue Worker:  build from same repo, point to railway.worker.json
#        - Scheduler:     build from same repo, point to railway.scheduler.json
#      Set the same variables below on each. Replace QUEUE_CONNECTION=sync here
#      if you create the worker service.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=TheraConnect
APP_ENV=production
APP_DEBUG=false
APP_KEY=                       # base64:... from `php artisan key:generate --show`
APP_URL=https://CHANGEME.up.railway.app
APP_TIMEZONE=UTC

# Database — Railway MySQL plugin references (auto-filled)
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# Sessions — DB-backed; secure cookie works because we trust Railway's proxy
# (see bootstrap/app.php's trustProxies). Encrypted sessions protect any
# clinician/admin PII stored in the session payload.
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true
SESSION_LIFETIME=120

# ── Pilot trade-off: queue worker + scheduler ────────────────────────────────
#
# If you deployed the queue-worker service (railway.worker.json), set
# QUEUE_CONNECTION=database. Otherwise the API still works but push notifications
# will be delivered inline with each HTTP response (and the scheduler below
# can't enqueue reminders). Setup.ps1 / docker-compose use the database driver
# out of the box.
QUEUE_CONNECTION=database

# ── Pilot trade-off: persistent private uploads ──────────────────────────────
#
# Files (assignment worksheets, submission uploads) are SENSITIVE patient
# content and MUST NOT be stored on the container's ephemeral filesystem —
# running deployments wipe /var/www/storage between releases.
#
# Recommended: use S3 (or any S3-compatible service). Create a PRIVATE bucket
# (block public access), an IAM user with s3:PutObject/GetObject/DeleteObject
# on the bucket, and set the AWS_* vars below. Setting AWS_BUCKET switches the
# app to the s3 disk automatically.
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=                    # when non-empty, the s3 disk is used (see config/filesystems.php)
AWS_USE_PATH_STYLE_ENDPOINT=false

CACHE_STORE=database

LOG_CHANNEL=stack
LOG_LEVEL=error

BCRYPT_ROUNDS=12

# ── CORS — restrict to the dashboard + Flutter app origins ───────────────────
# Keep "*" if you don't know yet — bearer-token API is safe even with permissive
# CORS because browsers won't auto-send credentials. Once you have a public
# domain, restrict like:
#   CORS_ALLOWED_ORIGINS=https://theraconnect-demo-production.up.railway.app
CORS_ALLOWED_ORIGINS=*

# Sanctum: the web dashboard's host (the Railway domain, no scheme)
SANCTUM_STATEFUL_DOMAINS=CHANGEME.up.railway.app

# Email is logged, not sent (no SMTP configured for the pilot)
MAIL_MAILER=log

# ── FCM (Firebase Cloud Messaging) push notifications ────────────────────────
#
# Push is OPTIONAL: leaving both vars empty disables push gracefully — in-app
# notifications still work because NotificationService writes the DB row
# synchronously before dispatching SendPushNotification. FcmService detects
# the missing config and no-ops (see app/Services/FcmService.php).
#
# To enable (recommended for production so patients get reminders even with
# the app backgrounded):
#   - Set FCM_PROJECT_ID to your Firebase project ID (Project Settings →
#     General → Project ID).
#   - Generate a service-account JSON key in Firebase Console → Project
#     Settings → Service Accounts → Generate New Private Key.
#   - Mount that JSON file into the container at a secret path (Railway
#     Variables tab → "Raw Editor" → set FCM_CREDENTIALS to an absolute path
#     like /var/www/storage/app/private/firebase-credentials.json).
#   - Never commit the JSON file to the repo.
FCM_PROJECT_ID=
FCM_CREDENTIALS=

# Jitsi video calling — public server, no credentials required. These match the
# config/services.php defaults, so setting them is optional (shown for clarity).
JITSI_BASE_URL=https://meet.jit.si
JITSI_ROOM_PREFIX=TheraConnect

# Chatbot AI engine (optional). Set GEMINI_API_KEY to have the patient chatbot
# answer via Google Gemini Flash, grounded on the seeded knowledge base, with
# graceful fallback to the rule-based matcher if the API is unreachable. Leave
# blank to keep the rule-based matcher only.
# HIPAA note: Railway is not HIPAA-eligible. The chatbot sends only the patient's
# typed message plus generic clinic FAQ — never names, appointments, or notes.
GEMINI_API_KEY=
GEMINI_CHATBOT_MODEL=gemini-2.0-flash
