APP_NAME=TheraConnect
APP_ENV=local
APP_KEY=
# Local dev: true is fine. For ANY non-local deploy, set false — exposing
# stack traces / env vars on errors is dangerous even for a "demo".
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=theraconnect
DB_USERNAME=root
DB_PASSWORD=

# Sessions are DB-backed for horizontal scalability. SESSION_ENCRYPT=true is
# recommended even for local dev — it has minimal overhead and ensures the
# production deploy also encrypts by default. Flip back to false only if you
# need to inspect session payloads during debugging.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# Storage: leave "local" for local dev (private uploads land in
# storage/app/private). For Railway or any non-ephemeral deploy, set this to
# "s3" and provide the AWS_* vars — private file uploads persist correctly
# only when the disk is non-ephemeral.
FILESYSTEM_DISK=local

# Job queue: "sync" runs jobs inline (no worker process) — fine for tests
# but means push notifications don't fire until the HTTP response returns.
# "database" requires a queue worker (see docker-compose.yml or
# railway.worker.json) but is the recommended choice for any real deploy.
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 — used only when FILESYSTEM_DISK=s3. Required for non-ephemeral
# private file uploads on Railway (the container filesystem is wiped on
# redeploy). Create an IAM user with s3:PutObject/GetObject/DeleteObject on
# the bucket; bucket should be private (block-public-access = on).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# CORS — comma-separated list of allowed origins for the JSON API.
# Leave "*" for local dev (bearer-token API is safe even with permissive CORS
# because browsers won't auto-send credentials). For prod, set to the dashboard
# domain + Flutter app's HTTP origin (if any), e.g.
#   CORS_ALLOWED_ORIGINS=https://theraconnect-demo-production.up.railway.app
CORS_ALLOWED_ORIGINS=*

VITE_APP_NAME="${APP_NAME}"

# Sanctum stateful domains (web dashboard domain)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Firebase Cloud Messaging (Phase 7) — leave empty to gracefully disable push.
# In prod: set FCM_PROJECT_ID to your Firebase project ID and FCM_CREDENTIALS
# to the absolute path of a service-account JSON credentials file (mount it
# as a secret; do NOT commit it). See config/services.php for usage.
FCM_PROJECT_ID=
FCM_CREDENTIALS=

# Jitsi video calling (public server; no credentials required)
JITSI_BASE_URL=https://meet.jit.si
JITSI_ROOM_PREFIX=TheraConnect

# Chatbot AI engine (optional). With a key set, the patient chatbot answers via
# Google Gemini grounded on the seeded knowledge base; leave blank to use the
# built-in rule-based (Jaccard) matcher. No PHI is sent — only the patient's
# typed message + generic clinic FAQ. (Note: Railway is not HIPAA-eligible.)
GEMINI_API_KEY=
GEMINI_CHATBOT_MODEL=gemini-2.0-flash
