# Broken-on-host symlink (absolute /var/www target); recreated at boot via `storage:link --force`
public/storage

# Recreated in the image by `composer install`; provided at runtime by the vendor volume
/vendor

# Frontend / mobile — not part of the backend image
/node_modules
/theraconnect_flutter

# VCS / CI / editor
.git
.github
.vscode

# Local env & caches (runtime uses the compose `environment:` block + mounted volume)
.env
.env.*
bootstrap/cache/*.php
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
.phpunit.result.cache

# Build artifacts
*.apk
